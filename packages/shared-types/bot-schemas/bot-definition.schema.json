{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://clashx.dev/schemas/bot-definition.schema.json",
  "title": "BotDefinition",
  "type": "object",
  "required": [
    "name",
    "visibility",
    "market_scope",
    "strategy_type",
    "authoring_mode",
    "rules_version",
    "rules_json"
  ],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 2,
      "maxLength": 120
    },
    "description": {
      "type": "string",
      "default": ""
    },
    "visibility": {
      "type": "string",
      "enum": ["private", "public", "unlisted"]
    },
    "market_scope": {
      "type": "string",
      "minLength": 2
    },
    "strategy_type": {
      "type": "string",
      "minLength": 2
    },
    "authoring_mode": {
      "type": "string",
      "enum": ["visual", "sdk"]
    },
    "rules_version": {
      "type": "integer",
      "minimum": 1
    },
    "rules_json": {
      "type": "object"
    },
    "sdk_bundle_ref": {
      "type": ["string", "null"]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "authoring_mode": {
            "const": "visual"
          }
        }
      },
      "then": {
        "properties": {
          "rules_json": {
            "type": "object",
            "required": ["conditions", "actions"],
            "properties": {
              "conditions": {
                "type": "array",
                "minItems": 1
              },
              "actions": {
                "type": "array",
                "minItems": 1
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "authoring_mode": {
            "const": "sdk"
          }
        }
      },
      "then": {
        "required": ["sdk_bundle_ref"]
      }
    }
  ]
}
